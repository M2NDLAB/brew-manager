# ─────────────────────────────────────────────────────────────────────────────
# brew-manager — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Session logs (auto-generated by brew_manager.sh via script(1))
logs/
brew_report_*.log

# Brewfile backups — contain local paths specific to your machine
backups/

# LaunchAgent configurations and activity log — local machine only
agents/

# ─────────────────────────────────────────────────────────────────────────────
# macOS system files
# ─────────────────────────────────────────────────────────────────────────────

.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Spotlight index
.Spotlight-V100
.Trashes

# ─────────────────────────────────────────────────────────────────────────────
# Editor artifacts
# ─────────────────────────────────────────────────────────────────────────────

# VSCode
.vscode/

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*

# ─────────────────────────────────────────────────────────────────────────────
# Temporary files created by brew-manager modules
# ─────────────────────────────────────────────────────────────────────────────

/tmp/brew_*.log
/tmp/brew_doctor.log
/tmp/brew_update.log
/tmp/brew_audit.log
/tmp/brew_adopt_err.log

# ─────────────────────────────────────────────────────────────────────────────
# Shell and script artifacts
# ─────────────────────────────────────────────────────────────────────────────

# zsh compiled script cache
*.zwc
*.zwc.old

# Bash history if accidentally placed here
.bash_history
.zsh_history

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code framework (merged from claude-code-framework v0.2.0)
# ─────────────────────────────────────────────────────────────────────────────

# Personal Claude Code permissions — never committed (see .claude/docs/04)
.claude/settings.local.json

# Obsidian vault metadata (the .claude/ folder can be opened as a vault)
.obsidian/

# Secrets baseline — this project has none by design, but keep the net anyway
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
**/secrets/

# ─────────────────────────────────────────────────────────────────────────────
# Do NOT ignore — these must be committed
# ─────────────────────────────────────────────────────────────────────────────

# The following are intentionally NOT excluded:
# brew_manager.sh
# lib/common.sh
# lib/log.sh
# modules/mod_*.sh
# README.md
# LICENSE
